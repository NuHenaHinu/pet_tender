# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ── Secrets / sensitive — NEVER commit ──────────────────────────────────────
# Environment variables (keep .env.example tracked as the template)
.env
.env.*
!.env.example

# Google OAuth client secret (downloaded from Google Cloud Console)
client_secret_*.json
*client_secret*.json

# Firebase / Google services configs (contain API keys)
google-services.json
GoogleService-Info.plist

# Android signing
*.jks
*.keystore
key.properties
**/key.properties

# Apple certificates / provisioning / keys
*.pem
*.p12
*.p8
*.cer
*.mobileprovision

# Machine-specific (root-anchored rule above misses the android/ copy)
android/local.properties
