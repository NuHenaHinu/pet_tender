# PeTender environment template.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
#   cp .env.example .env

# ── Backendless (Console → Manage → API Keys → REST) ─────────────────────────
BACKENDLESS_APP_ID=
BACKENDLESS_API_KEY=

# ── The Dog API / The Cat API (https://thedogapi.com / https://thecatapi.com) ─
DOG_API_KEY=
CAT_API_KEY=

# ── Optional / native-side keys ──────────────────────────────────────────────
# Google Maps key lives in AndroidManifest.xml + iOS AppDelegate, not here.
# GOOGLE_MAPS_API_KEY=
# LINE_CHANNEL_ID=
